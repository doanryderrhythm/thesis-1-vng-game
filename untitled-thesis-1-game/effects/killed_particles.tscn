@onready var anim_player: AnimationPlayer = $AnimationPlayer
@onready var glow: Sprite2D = $Glow

func _ready() -> void:
	emitting = true
	glow.self_modulate = color
	anim_player.play(\"default\")

func _on_finished() -> void:
	queue_free()
	pass # Replace with function body.
