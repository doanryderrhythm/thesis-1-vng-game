[sub_resource type="GDScript" id="GDScript_w3ui0"]
resource_name = "main_menu"
script/source = "extends Node2D

@onready var difficulty_selection: ColorRect = $UI/DifficultySelect
@onready var character_warning: ColorRect = $UI/Warning

func _ready() -> void:
	RenderingServer.set_default_clear_color(Color(0.029, 0.0, 0.184, 1.0))
	Input.mouse_mode = Input.MOUSE_MODE_VISIBLE
	
	MusicManager.stop_gameplay_music()
	MusicManager.reset_pitch()
	MusicManager.toggle_filter_effect(false)
	LoadSystem.load_game()

func _on_play_button_pressed() -> void:
	if ProfileManager.player_code == \"\":
		show_overlay_info(character_warning, true)
		return
	
	show_overlay_info(difficulty_selection, true)
	pass # Replace with function body.

func show_overlay_info(object, is_toggled: bool) -> void:
	if is_toggled:
		object.visible = true
		object.set_process_mode(Node.PROCESS_MODE_INHERIT)
	else:
		object.visible = false
		object.set_process_mode(Node.PROCESS_MODE_DISABLED)

func start_game(level_type: GameManager.LevelType) -> void:
	if ProfileManager.player_code == \"\":
		return
	
	GameManager.level_type = level_type
	get_tree().change_scene_to_file(\"res://scenes/main_scenes/play_scene.tscn\")

func _on_play_normal_button_pressed() -> void:
	start_game(GameManager.LevelType.LEVEL_NORMAL)
	pass # Replace with function body.

func _on_play_terrain_button_pressed() -> void:
	start_game(GameManager.LevelType.LEVEL_TERRAIN)
	pass # Replace with function body.

func _on_play_icy_button_pressed() -> void:
	start_game(GameManager.LevelType.LEVEL_ICY)
	pass # Replace with function body.

func _on_achievement_button_pressed() -> void:
	get_tree().change_scene_to_file(\"res://scenes/main_scenes/achievement.tscn\")
	pass # Replace with function body.

func _on_shop_button_pressed() -> void:
	get_tree().change_scene_to_file(\"res://scenes/main_scenes/shop_scene.tscn\")
	pass # Replace with function body.

func _on_difficulty_back_button_pressed() -> void:
	show_overlay_info(difficulty_selection, false)
	pass # Replace with function body.

func _on_warning_back_button_pressed() -> void:
	show_overlay_info(character_warning, false)
	pass # Replace with function body.
"

[sub_resource type="GDScript" id="GDScript_qd03l"]
resource_name = "button_behaviour"
script/source = "extends TextureButton

@onready var text: Label = $Label

func _process(_delta: float) -> void:
	if is_hovered() and disabled == false:
		text.label_settings.font_color = Color.BLACK
	else:
		text.label_settings.font_color = Color.WHITE
"

[sub_resource type="LabelSettings" id="LabelSettings_bi8wh"]
font = ExtResource("4_qd03l")
font_size = 80

